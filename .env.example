# Example environment variables for Chronos-AI.
# Copy this file to `.env` and fill in the real values locally (do NOT commit `.env`).

# Deriv credentials
DERIV_APP_ID=12345
DERIV_API_TOKEN=your_deriv_api_token_here

# Execution (paper v1: Deriv). Leave disabled until ready to place demo orders.
# EXECUTION_ENABLED=1
# EXECUTION_PAPER_ONLY=true
# EXECUTION_PROVIDER=deriv
# Use stub provider for tests without a broker: EXECUTION_PROVIDER=stub

# Database (required). PostgreSQL in production; SQLite is fine for local dev, e.g.:
# DATABASE_URL=sqlite:///./ikenga.db
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/chronos_ai

# MongoDB (for future use: logging, results storage, etc.)
MONGO_URI=mongodb+srv://user:password@cluster-url/dbname
MONGO_DB_NAME=chronos_ai
MONGO_COLLECTION_PREFIX=chronos
